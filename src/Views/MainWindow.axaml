<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PingBox.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="640"
        x:Class="PingBox.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/pingbox.ico"
        Title="{Binding Title}"
        Width="{Binding Width}"
        Height="{Binding Height}"
        ShowInTaskbar="{Binding ShowInTaskbar}"
        Topmost="{Binding TopMost}"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FB"
        DragDrop.DragOver="MainWindow_DragOver"
        DragDrop.Drop="MainWindow_Drop">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F3F6FB" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#F9FBFF" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#D6E1EF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6B7280" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#111827" />
        </Style>

        <Style Selector="Button.toolbar">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#D1D9E6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#111827" />
        </Style>

        <Style Selector="Button.card">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="MinHeight" Value="140" />
            <Setter Property="Foreground" Value="#111827" />
        </Style>

        <Style Selector="Button.card:pointerover">
            <Setter Property="Background" Value="#E7EFFB" />
        </Style>

        <Style Selector="Button.card:pressed">
            <Setter Property="Background" Value="#DCE9F7" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*" Background="{StaticResource WindowBackgroundBrush}">
        <Border Grid.Row="0" Background="{StaticResource ToolbarBackgroundBrush}" Padding="18" BorderBrush="#E5E9F0" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                <StackPanel Orientation="Vertical" Spacing="2">
                        <TextBlock Text="{Binding Title}" Classes="h1" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Classes="toolbar" Content="添加程序" ToolTip.Tip="添加程序到当前页面" Command="{Binding AddProgramCommand}" />
                    <Button Classes="toolbar" Content="添加目录" ToolTip.Tip="添加目录到当前页面" Command="{Binding AddDirectoryCommand}" />
                    <Button Classes="toolbar" Content="新增页面" ToolTip.Tip="添加新页面" Command="{Binding AddPageCommand}" />
                    <Button Classes="toolbar" Content="删除页面" ToolTip.Tip="删除当前页面" Command="{Binding RemovePageCommand}" />
                    <Button Classes="toolbar" Content="设置" ToolTip.Tip="打开设置" Click="ShowSettingsButton_Click" />
                    <Button Classes="toolbar" Content="关于" ToolTip.Tip="关于PingBox" Click="ShowAboutButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="16,12,16,0" Background="{StaticResource PanelBackgroundBrush}" CornerRadius="14" Padding="12" BorderBrush="#E5E9F0" BorderThickness="1">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBox Width="360" Watermark="搜索所有页面..." Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <Button Classes="toolbar" Content="清除" Command="{Binding ClearSearchCommand}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Margin="16" Background="{StaticResource PanelBackgroundBrush}" CornerRadius="18" Padding="18" BorderBrush="#E5E9F0" BorderThickness="1">
            <StackPanel Spacing="18">
                <StackPanel IsVisible="{Binding IsSearchActive}" Spacing="14">
                    <TextBlock Text="搜索结果" FontSize="16" FontWeight="SemiBold" />
                    <ItemsControl ItemsSource="{Binding SearchResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SearchResultViewModel">
                                <StackPanel>
                                    <TextBlock Text="{Binding PageName}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" ItemWidth="140" ItemHeight="160" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:PageItemViewModel">
                                                <Button Classes="card" Margin="10" Command="{Binding RunCommand}" PointerPressed="PageItem_PointerPressed" PointerReleased="PageItem_PointerReleased">
                                                    <Button.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="打开" Command="{Binding RunCommand}" />
                                                            <MenuItem Header="在资源管理器中显示" Command="{Binding ShowInExplorerCommand}" />
                                                            <MenuItem Header="删除" Command="{Binding DeleteCommand}" />
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                                                        <Image Source="{Binding Icon}" Width="48" Height="48" />
                                                        <TextBlock Text="{Binding Name}" Foreground="#111827" TextAlignment="Center" TextWrapping="Wrap" Margin="0,2,0,0" FontSize="13" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding CategoryLabel}" Foreground="{StaticResource MutedTextBrush}" FontSize="10" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <TabControl IsVisible="{Binding IsSearchInactive}" ItemsSource="{Binding Pages}" SelectedIndex="{Binding SelectedIndex}" Background="Transparent">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Margin="0,0,0,0" />
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:PageViewModel">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <StackPanel Orientation="Vertical" Spacing="18">
                                    <StackPanel>
                                        <TextBlock Text="软件" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                                        <ItemsControl ItemsSource="{Binding SoftwareItems}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" ItemWidth="140" ItemHeight="160" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:PageItemViewModel">
                                                    <Button Classes="card" Margin="10" Command="{Binding RunCommand}" PointerPressed="PageItem_PointerPressed" PointerReleased="PageItem_PointerReleased">
                                                        <Button.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="打开" Command="{Binding RunCommand}" />
                                                                <MenuItem Header="在资源管理器中显示" Command="{Binding ShowInExplorerCommand}" />
                                                                <MenuItem Header="删除" Command="{Binding DeleteCommand}" />
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                                                            <Image Source="{Binding Icon}" Width="48" Height="48" />
                                                            <TextBlock Text="{Binding Name}" Foreground="#111827" TextAlignment="Center" TextWrapping="Wrap" Margin="0,2,0,0" FontSize="13" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding FullPath}" Foreground="{StaticResource MutedTextBrush}" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="120" FontSize="10" />
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="文件夹" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                                        <ItemsControl ItemsSource="{Binding FolderItems}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" ItemWidth="140" ItemHeight="160" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:PageItemViewModel">
                                                    <Button Classes="card" Margin="10" Command="{Binding RunCommand}" PointerPressed="PageItem_PointerPressed" PointerReleased="PageItem_PointerReleased">
                                                        <Button.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="打开" Command="{Binding RunCommand}" />
                                                                <MenuItem Header="在资源管理器中显示" Command="{Binding ShowInExplorerCommand}" />
                                                                <MenuItem Header="删除" Command="{Binding DeleteCommand}" />
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                                                            <Image Source="{Binding Icon}" Width="48" Height="48" />
                                                            <TextBlock Text="{Binding Name}" Foreground="#111827" TextAlignment="Center" TextWrapping="Wrap" Margin="0,2,0,0" FontSize="13" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding FullPath}" Foreground="{StaticResource MutedTextBrush}" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="120" FontSize="10" />
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="文件" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                                        <ItemsControl ItemsSource="{Binding FileItems}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" ItemWidth="140" ItemHeight="160" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:PageItemViewModel">
                                                    <Button Classes="card" Margin="10" Command="{Binding RunCommand}" PointerPressed="PageItem_PointerPressed" PointerReleased="PageItem_PointerReleased">
                                                        <Button.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="打开" Command="{Binding RunCommand}" />
                                                                <MenuItem Header="在资源管理器中显示" Command="{Binding ShowInExplorerCommand}" />
                                                                <MenuItem Header="删除" Command="{Binding DeleteCommand}" />
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                                                            <Image Source="{Binding Icon}" Width="48" Height="48" />
                                                            <TextBlock Text="{Binding Name}" Foreground="#111827" TextAlignment="Center" TextWrapping="Wrap" Margin="0,2,0,0" FontSize="13" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding FullPath}" Foreground="{StaticResource MutedTextBrush}" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="120" FontSize="10" />
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </StackPanel>
        </Border>
    </Grid>
</Window>
