<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="300"
        x:Class="PingBox.Views.AboutWindow"
        Title="关于 PingBox"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight">

    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
        <Image Grid.Row="0" Source="/Assets/pingbox.ico" Width="64" Height="64"
               HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="PingBox" FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2" x:Name="txtVersion" Text="版本: 1.0.0"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="3" Text="一个简洁实用的程序启动器"
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Button Grid.Row="4" Content="确定" Width="80" HorizontalAlignment="Center"
                Click="OnOkClick"/>
    </Grid>
</Window>