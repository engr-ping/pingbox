<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="PingBox.Views.SettingsWindow"
        Title="设置 - PingBox"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight">

    <Window.Styles>
        <Style Selector="TextBox.input">
            <Setter Property="Background" Value="#F3F6FB" />
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="BorderBrush" Value="#9CB0CB" />
            <Setter Property="CaretBrush" Value="#1F2937" />
        </Style>

        <Style Selector="TextBox.input:focus">
            <Setter Property="Background" Value="#F3F6FB" />
            <Setter Property="BorderBrush" Value="#5C7DB8" />
        </Style>

        <Style Selector="TextBox.input:pointerover">
            <Setter Property="Background" Value="#F3F6FB" />
            <Setter Property="BorderBrush" Value="#7F98BB" />
        </Style>

        <Style Selector="TextBox.input /template/ Border#border">
            <Setter Property="Background" Value="#F3F6FB" />
        </Style>

        <Style Selector="TextBox.input:pointerover /template/ Border#border">
            <Setter Property="Background" Value="#F3F6FB" />
        </Style>

        <Style Selector="TextBox.input:focus:pointerover">
            <Setter Property="Background" Value="#F3F6FB" />
            <Setter Property="BorderBrush" Value="#5C7DB8" />
        </Style>

        <Style Selector="TextBox.input:focus /template/ Border#border">
            <Setter Property="Background" Value="#F3F6FB" />
        </Style>

        <Style Selector="TextBox.input:focus:pointerover /template/ Border#border">
            <Setter Property="Background" Value="#F3F6FB" />
        </Style>
    </Window.Styles>

    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto" ColumnDefinitions="Auto,*">
        <!-- 通用设置 -->
        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="通用设置" FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                  x:Name="chkShowInTaskbar" Content="显示在任务栏"
                  Margin="0,0,0,10"/>

        <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                  x:Name="chkTopMost" Content="窗口置顶"
                  Margin="0,0,0,10"/>

        <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                  x:Name="chkHideOnStart" Content="启动时隐藏"
                  Margin="0,0,0,10"/>

        <CheckBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                  x:Name="chkNoExit" Content="关闭时隐藏（不退出）"
                  Margin="0,0,0,10"/>

        <CheckBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                  x:Name="chkHideOnRun" Content="启动程序后隐藏窗口"
                  Margin="0,0,0,10"/>

        <CheckBox Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                  x:Name="chkAutoStart" Content="开机自动启动"
                  Margin="0,0,0,15"/>

        <!-- 热键设置 -->
        <TextBlock Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="热键设置" FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <CheckBox Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                  x:Name="chkHotkeyEnabled" Content="启用全局热键（显示/隐藏窗口）"
                  Margin="0,0,0,10"/>

        <TextBlock Grid.Row="9" Grid.Column="0" Text="热键："
                   VerticalAlignment="Center" Margin="0,0,10,0"/>
        <TextBox Grid.Row="9" Grid.Column="1" Classes="input" x:Name="txtHotkey"
                 Width="200" IsReadOnly="True"
                 ToolTip.Tip="点击后按组合键设置热键"/>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="10" Margin="0,20,0,0">
            <Button Content="取消" Width="80" Click="OnCancelClick"/>
            <Button Content="确定" Width="80" Click="OnOkClick"/>
        </StackPanel>
    </Grid>
</Window>